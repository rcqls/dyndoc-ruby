#!/usr/bin/env ruby
require 'dyndoc-html-servers'

if ["--no-forever","--no-daemon"].include? ARGV[0]
  Dyndoc::HtmlServers.dyn_http_server
else
  require 'daemons'
  require 'dyndoc/init/home'
  require 'fileutils'

  dir_pids=File.join(Dyndoc.home,"pids")
  dir_log=File.join(Dyndoc.home,"log")
  FileUtils.mkdir_p dir_pids
  FileUtils.mkdir_p dir_log
  Daemons.run_proc('dyn-http',{dir: dir_pids, backtrace: true, log_dir: dir_log}) do
      Dyndoc::HtmlServers.dyn_http_server
  end

end
